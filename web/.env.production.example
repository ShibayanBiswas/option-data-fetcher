# Option Chain Archive — environment for VPS / Docker
# Copy to .env.production on the server (do not commit secrets).

# On-disk SQLite (recommended). Do NOT set a libsql:// Turso URL for VPS deploys.
# systemd + standalone: relative path with WorkingDirectory=.../standalone
LIBSQL_URL=file:./data/option_chain.db
# Docker Compose: absolute path inside the container:
# LIBSQL_URL=file:/app/data/option_chain.db

# Required in production for privileged sync / cron-style scripts
CRON_SECRET=replace_with_openssl_rand_hex_32
SYNC_SECRET=replace_with_different_openssl_rand_hex_32
