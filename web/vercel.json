{
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "0 14 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/api/(tree|browse)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=60, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/api/sync",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=120, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
