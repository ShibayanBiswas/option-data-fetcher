{
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "30 11 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/api/(tree|browse)",
      "headers": [
        { "key": "Cache-Control", "value": "private, max-age=30" }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
