{
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "0 14 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/api/(tree|browse)",
      "headers": [
        { "key": "Cache-Control", "value": "private, max-age=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
