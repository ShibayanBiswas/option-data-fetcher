# Local SQLite archive (default if unset)
SQLITE_URL=file:./data/option_chain.db

# Optional aliases (file: paths only — remote URLs are rejected)
# LIBSQL_URL=file:./data/option_chain.db

# Secrets for Sync Today / cron-style scripts
CRON_SECRET=change-me
SYNC_SECRET=change-me

# Skip writing CSV mirrors under data/store (1 = skip)
# SKIP_LOCAL_STORE=1
