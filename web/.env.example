# Local desk (default) — file SQLite
SQLITE_URL=file:./data/option_chain.db

# Vercel / Turso — set these for production + `npm run seed:turso:fast`
# Create DB at https://turso.tech  (paid plan recommended for full archive)
LIBSQL_URL=libsql://YOUR-DB.turso.io
LIBSQL_AUTH_TOKEN=

# Optional aliases
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# Vercel cron + Sync Today
CRON_SECRET=change-me
SYNC_SECRET=change-me

# Skip writing CSVs under data/store during remote sync (saves disk)
SKIP_LOCAL_STORE=1
