# Local desk (default) — file SQLite. Desk work does NOT hit Turso.
SQLITE_URL=file:./data/option_chain.db

# Turso (used on Vercel automatically, or locally with USE_TURSO=1)
LIBSQL_URL=libsql://YOUR-DB.turso.io
LIBSQL_AUTH_TOKEN=

# Keep archive from this date forward
ARCHIVE_EPOCH=2025-01-01

# Force Turso from laptop: USE_TURSO=1 npm run push:stats

CRON_SECRET=change-me
SYNC_SECRET=change-me
SKIP_LOCAL_STORE=1
